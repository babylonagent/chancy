# Chancy deployment/API env
# Copy to .env locally. Never commit real private keys or RPC/API keys.

# Deployer key for Base/Base Sepolia deployments. Runtime host only.
PRIVATE_KEY=

# RPC URLs. Public fallbacks exist in hardhat.config.js, but production deploys should use a reliable RPC.
# Runtime host only; do not store real RPC API keys in Git, Vercel, or docs.
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# ChancyGame constructor args.
# Owner/controller wallet can differ from the deployer wallet.
CHANCY_OWNER_ADDRESS=
# Base mainnet USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia Circle USDC: 0x036cbd53842c5426634e7929541ec2318f3dcf7e
CHANCY_USDC_ADDRESS=

# Pyth Entropy contract for target chain.
# Verify with getCode/getDefaultProvider/getFeeV2 before deploy; do not trust copied addresses blindly.
PYTH_ENTROPY_ADDRESS=

# Agent/API transaction builder.
CHANCY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PORT=8787

# Optional web build-time public config. Addresses only; no secrets.
VITE_CHANCY_API_URL=
VITE_CHANCY_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VITE_CHANCY_BASE_SEPOLIA_USDC_ADDRESS=0x036cbd53842c5426634e7929541ec2318f3dcf7e
