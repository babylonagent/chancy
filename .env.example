# Chancy deployment/API env
# Copy to .env locally. Never commit real private keys.

# Deployer key for Base/Base Sepolia deployments.
PRIVATE_KEY=

# RPC URLs. Public fallbacks exist in hardhat.config.js, but production deploys should use a reliable RPC.
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# ChancyGame constructor args.
# Sessions settle in native ETH or USDC. Provide the USDC token address for the
# target network (e.g. USDC on Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913).
CHANCY_USDC_ADDRESS=
PYTH_ENTROPY_ADDRESS=

# Agent/API transaction builder.
CHANCY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PORT=8787
