{
  "version": 2,
  "buildCommand": "npm run web:build",
  "outputDirectory": "dist/web",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "apps/api/server.js"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/v2/(.*)", "destination": "/api/$1" },
    { "source": "/data/(.*)", "destination": "/api/$1" },
    { "source": "/tx/(.*)", "destination": "/api/$1" },
    { "source": "/read/(.*)", "destination": "/api/$1" }
  ]
}
